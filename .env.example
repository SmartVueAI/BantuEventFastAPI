# Application Settings
APP_NAME=E-Commerce API
APP_VERSION=1.0.0
DEBUG=False
ENVIRONMENT=production

# Database Configuration
DB_USER=ecommerce_user
DB_PASSWORD=your_secure_password_here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce_db
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-minimum-32-characters-long-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=2

# Security
SECRET_KEY=your-security-stamp-secret-key-change-this
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# SMTP Configuration (Gmail Example)
SMTP_HOST="mail5008.site4now.net"
SMTP_PORT=465 
SMTP_USER="no-reply@smartvueai.com"
SMTP_PASSWORD="Diamond$345"
SMTP_FROM="no-reply@smartvueai.com"
SMTP_FROM_NAME="Sonma Hair"
EMAIL_USE_SSL=True


# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,https://yourdomain.com

# File Upload Settings
MAX_FILE_SIZE_MB=5
ALLOWED_IMAGE_TYPES = "jpg,jpeg,png,gif,webp"

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
LOGIN_RATE_LIMIT_PER_MINUTE=5

# Logging
LOG_LEVEL=INFO

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000