# ========================================
# Redis Configuration
# ========================================
REDIS_URL="redis://localhost:6379/0"

# ========================================
# CORS Configuration
# ========================================
# Comma-separated list of allowed origins
# For development: http://localhost:3000,http://localhost:8080
# For production: https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS="http://localhost:3000,http://localhost:8000,https://sonmahair.com"

# ========================================
# File Upload Settings
# ========================================
MAX_FILE_SIZE_MB=5
ALLOWED_IMAGE_TYPES= "jpg,jpeg,png,gif,webp"

# ========================================
# Rate Limiting
# ========================================
RATE_LIMIT_PER_MINUTE=100
LOGIN_RATE_LIMIT_PER_MINUTE=5

# ========================================
# Logging Configuration
# ========================================
LOG_LEVEL="INFO"

# ========================================
# Frontend URL
# ========================================
# Used for email links (verification, password reset, etc.)
FRONTEND_BASE_URL=https://sonmahair.com

# ========================================
# Base URL (for generated links)
# ========================================
BASE_URL="https://mainapi.sonmahair.com"

# ========================================
# Docker-specific (uncomment when using Docker)
# ========================================
# DB_HOST=db
# REDIS_URL=redis://redis:6379/0

# ========================================
# Production Settings (uncomment for production)
# ========================================
# DEBUG=False
# ENVIRONMENT=production
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# FRONTEND_URL=https://yourdomain.com
# BASE_URL=https://api.yourdomain.com

# ========================================
# Test Database (for running tests)
# ========================================
TEST_DATABASE_URL=postgresql+asyncpg://test_user:test_pass@localhost:5432/test_ecommerce_db

# ========================================
# Optional: Sentry (Error Tracking)
# ========================================
# SENTRY_DSN=your-sentry-dsn-here

# ========================================
# Optional: AWS S3 (for file storage)
# ========================================
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_S3_BUCKET_NAME=your-bucket-name
# AWS_REGION=us-east-1

# ========================================
# SETUP INSTRUCTIONS
# ========================================
# 1. Copy this file to .env: cp .env.example .env
# 2. Generate secure keys:
#    python -c "import secrets; print('JWT_SECRET_KEY=' + secrets.token_hex(32))"
#    python -c "import secrets; print('SECRET_KEY=' + secrets.token_hex(32))"
# 3. Update DB_PASSWORD with a strong password
# 4. Configure SMTP settings (Gmail, SendGrid, etc.)
# 5. Update ALLOWED_HOSTS with your domain
# 6. Update CORS_ORIGINS with your frontend URL
# 7. Update FRONTEND_URL with your frontend URL
# 8. Never commit this file to Git!
# ========================================